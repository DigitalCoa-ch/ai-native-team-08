/* ── Animations ── */
@keyframes ping { 75%, 100% { transform: scale(2); opacity: 0; } }
@keyframes glow { 0%, 100% { box-shadow: 0 0 20px rgba(99,102,241,0.35); } 50% { box-shadow: 0 0 50px rgba(99,102,241,0.8); } }
@keyframes slideUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
@keyframes gaugeDraw { from { stroke-dashoffset: var(--circ); } to { stroke-dashoffset: var(--offset); } }

/* ── Base ── */
*, *::before, *::after { box-sizing: border-box; }
body { margin: 0; background: #030712; color: #f1f5f9; font-family: 'Inter', system-ui, sans-serif; }

/* ── Layout ── */
.main { min-height: 100vh; }
.container { max-width: 1100px; margin: 0 auto; }

/* ── Top Bar ── */
.topbar {
  display: flex; align-items: center; justify-content: space-between;
  padding: 0.7rem 2rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  background: rgba(3,7,18,0.92); backdrop-filter: blur(16px);
  position: sticky; top: 0; z-index: 100;
}
.topbar-brand { display: flex; align-items: center; gap: 0.75rem; }
.brand-logo {
  width: 34px; height: 34px; border-radius: 9px;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  display: flex; align-items: center; justify-content: center;
  font-weight: 900; font-size: 0.85rem; color: #fff;
}
.brand-name { font-weight: 800; font-size: 0.92rem; letter-spacing: -0.01em; }
.brand-sub { font-size: 0.6rem; color: #475569; text-transform: uppercase; letter-spacing: 0.1em; }
.topbar-nav { display: flex; gap: 1.6rem; font-size: 0.8rem; color: #64748b; cursor: pointer; }
.topbar-status { display: flex; align-items: center; gap: 0.6rem; }
.status-dot { width: 7px; height: 7px; border-radius: 50%; background: #34d399; animation: ping 2s infinite; }
.topbar-status span { font-size: 0.7rem; color: #34d399; font-family: 'JetBrains Mono', monospace; letter-spacing: 0.05em; }

/* ── Hero ── */
.hero {
  padding: 4.5rem 2rem 3.5rem;
  border-bottom: 1px solid rgba(255,255,255,0.05);
  position: relative; overflow: hidden;
}
.hero-grid-bg {
  position: absolute; inset: 0; opacity: 0.04;
  background-image: radial-gradient(circle, rgba(99,102,241,0.8) 1px, transparent 1px);
  background-size: 32px 32px;
}
.hero-glow {
  position: absolute; top: -120px; left: 50%; transform: translateX(-50%);
  width: 700px; height: 350px; border-radius: 50%;
  background: radial-gradient(ellipse, rgba(99,102,241,0.12) 0%, transparent 65%);
  pointer-events: none;
}
.hero-content { max-width: 1100px; margin: 0 auto; position: relative; }
.hero-badge {
  display: inline-flex; align-items: center; gap: 0.5rem;
  padding: 0.3rem 0.9rem; border-radius: 999px;
  border: 1px solid rgba(99,102,241,0.4); background: rgba(99,102,241,0.07);
  font-size: 0.68rem; color: #818cf8; text-transform: uppercase; letter-spacing: 0.12em; font-weight: 700; margin-bottom: 1.5rem;
}
.badge-dot { width: 6px; height: 6px; border-radius: 50%; background: #6366f1; animation: ping 1.8s infinite; }
.hero-title {
  font-size: clamp(2.2rem, 5.5vw, 4rem); font-weight: 900; line-height: 1.05;
  letter-spacing: -0.025em; margin-bottom: 1.2rem; max-width: 720;
}
.hero-gradient {
  background: linear-gradient(90deg, #818cf8, #c084fc); -webkit-background-clip: text; -webkit-text-fill-color: transparent;
}
.hero-desc { font-size: 1.1rem; color: #64748b; line-height: 1.75; max-width: 540; margin-bottom: 2.2rem; }
.hero-ctas { display: flex; gap: 1rem; flex-wrap: wrap; }

/* ── Buttons ── */
.btn-primary {
  padding: 0.9rem 2.2rem; border-radius: 10px;
  background: linear-gradient(135deg, #6366f1, #7c3aed);
  border: none; color: #fff; font-weight: 800; font-size: 0.95rem; cursor: pointer;
  letter-spacing: -0.01em;
}
.btn-secondary {
  padding: 0.9rem 2.2rem; border-radius: 10px;
  border: 1px solid rgba(255,255,255,0.12); background: transparent;
  color: #94a3b8; font-weight: 600; font-size: 0.95rem; cursor: pointer;
}

/* ── Metrics ── */
.metrics-section { padding: 2.5rem 2rem; border-bottom: 1px solid rgba(255,255,255,0.05); }
.section-label { display: flex; align-items: center; gap: 0.5rem; margin-bottom: 1.2rem; font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: #34d399; font-weight: 700; }
.section-dot { width: 6px; height: 6px; border-radius: 50%; background: #34d399; animation: ping 2s infinite; }
.metrics-grid { display: flex; gap: 1rem; flex-wrap: wrap; }

/* ── Metric Card ── */
.metric-card {
  background: linear-gradient(135deg, #0f172a, #1e293b);
  border: 1px solid rgba(99,102,241,0.2); border-radius: 12px;
  padding: 1.4rem 1.6rem; flex: 1; min-width: 180px;
  animation: slideUp 0.5s ease both;
}
.metric-label { font-size: 0.72rem; text-transform: uppercase; letter-spacing: 0.1em; color: #64748b; font-weight: 600; margin-bottom: 0.6rem; }
.metric-value { font-size: 2rem; font-weight: 800; color: #f1f5f9; line-height: 1; }
.metric-delta { font-size: 0.8rem; margin-top: 0.5rem; font-weight: 600; }

/* ── Dashboard Grid ── */
.dashboard-section { padding: 2.5rem 2rem; }
.dashboard-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }

/* ── Panels ── */
.panel { background: linear-gradient(135deg, #0f172a, #1a1f35); border-radius: 14px; padding: 1.5rem; }
.panel-alert { border: 1px solid rgba(239,68,68,0.2); }
.panel-risk { border: 1px solid rgba(99,102,241,0.2); }
.panel-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 1.2rem; }
.panel-title { display: flex; align-items: center; gap: 0.5rem; }
.panel-title-text { font-size: 0.68rem; text-transform: uppercase; letter-spacing: 0.1em; color: #ef4444; font-weight: 700; }
.panel-meta { font-size: 0.68rem; color: #475569; font-family: 'JetBrains Mono', monospace; }
.panel-badge { font-size: 0.65rem; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 700; }
.alert-badge { background: rgba(239,68,68,0.15); color: #ef4444; }
.risk-badge { background: rgba(99,102,241,0.15); color: #818cf8; }

/* ── Alert Row ── */
.alert-row {
  display: flex; align-items: flex-start; gap: 0.8rem;
  padding: 0.9rem 1rem; border-radius: 8px; margin-bottom: 0.5rem;
  border: 1px solid;
  animation: slideUp 0.4s ease both;
}
.pulse-dot {
  width: 10px; height: 10px; border-radius: 50%; flex-shrink: 0;
  position: relative; display: inline-block;
}
.pulse-dot::before { content: ''; position: absolute; inset: 0; border-radius: 50%; animation: ping 1.5s cubic-bezier(0,0,0.2,1) infinite; }
.alert-body { flex: 1; min-width: 0; }
.alert-header { display: flex; align-items: center; gap: 0.5rem; flex-wrap: wrap; margin-bottom: 0.2rem; }
.alert-influencer { font-weight: 700; font-size: 0.85rem; color: #f1f5f9; }
.alert-severity { font-size: 0.68rem; padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; }
.alert-message { font-size: 0.78rem; color: #94a3b8; line-height: 1.4; }
.alert-time { font-size: 0.68rem; color: #475569; white-space: nowrap; font-family: 'JetBrains Mono', monospace; margin-top: 0.1rem; }

/* ── Scan Row ── */
.scan-row {
  display: flex; align-items: center; gap: 1rem;
  padding: 0.6rem 0; border-bottom: 1px solid #1e293b;
  animation: slideUp 0.4s ease both;
}
.scan-name { flex: 1; font-size: 0.88rem; color: #94a3b8; }
.scan-bar { width: 110px; height: 4px; background: #1e293b; border-radius: 4px; overflow: hidden; }
.scan-fill { height: 100%; border-radius: 4px; }
.scan-score { width: 44px; text-align: right; font-size: 0.78rem; font-weight: 700; font-family: 'JetBrains Mono', monospace; }
.scan-trend { width: 50px; text-align: right; font-size: 0.72rem; color: #34d399; font-family: 'JetBrains Mono', monospace; }

/* ── Gauges ── */
.gauge-section { padding: 3rem 2rem; border-top: 1px solid rgba(255,255,255,0.05); }
.gauges-row { display: flex; justify-content: center; gap: 2rem; flex-wrap: wrap; }
.risk-gauge { text-align: center; }
.gauge-label { font-size: 0.68rem; color: #64748b; margin-top: 0.4rem; text-transform: uppercase; letter-spacing: 0.06em; }
.gauge-arc { --circ: 238.76; --offset: 0; transition: stroke-dashoffset 1.5s ease; }
.gauge-footer { font-size: 0.75rem; color: #334155; margin-top: 1rem; font-family: 'JetBrains Mono', monospace; }

/* ── Footer ── */
.site-footer {
  padding: 1.5rem 2rem; border-top: 1px solid rgba(255,255,255,0.05);
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 0.5rem;
  font-size: 0.72rem; color: #334155;
}

/* ── Animation helpers ── */
.slide-up { animation: slideUp 0.5s ease both; }
.d1 { animation-delay: 0.1s; } .d2 { animation-delay: 0.2s; } .d3 { animation-delay: 0.3s; }
.glow-btn { animation: glow 3s ease-in-out infinite; }